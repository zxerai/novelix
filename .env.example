# JiaOS Environment Configuration
# Copy to .env and fill in your values
# NOTE: If using Studio, configure LLM via the web UI instead.
# .env is only used by CLI / daemon / deployment environments.

# =============================================================================
# LLM Configuration (CLI / daemon mode)
# =============================================================================

# Service provider (kkaiapi, openrouter, newapi, siliconcloud, google, moonshot,
#                    minimax, zhipu, bailian, deepseek, ppio, ollama, openai,
#                    anthropic, custom, or empty for auto-detect)
# JIAOS_LLM_SERVICE=

# Provider name (openai, anthropic, custom)
JIAOS_LLM_PROVIDER=openai

# API endpoint base URL
JIAOS_LLM_BASE_URL=https://api.openai.com/v1

# API Key
JIAOS_LLM_API_KEY=sk-your-key-here

# Model name
JIAOS_LLM_MODEL=gpt-4o

# API format (chat or responses)
# JIAOS_LLM_API_FORMAT=chat

# Enable streaming
# JIAOS_LLM_STREAM=true

# Temperature
# JIAOS_LLM_TEMPERATURE=0.7

# Max output tokens
# JIAOS_LLM_MAX_TOKENS=8192

# Extended thinking budget (Anthropic, 0 = disabled)
# JIAOS_LLM_THINKING_BUDGET=0

# Writing language (zh or en)
# JIAOS_DEFAULT_LANGUAGE=zh

# HTTP proxy for LLM requests
# JIAOS_LLM_PROXY_URL=http://127.0.0.1:7890

# Extra LLM parameters (JSON)
# JIAOS_LLM_EXTRA_top_p=0.9

# =============================================================================
# Web Search (optional)
# =============================================================================

# Tavily API key for Radar agent
# TAVILY_API_KEY=tvly-xxxxx

# =============================================================================
# Notifications (optional, for daemon mode)
# =============================================================================

# Telegram
# JIAOS_TELEGRAM_BOT_TOKEN=
# JIAOS_TELEGRAM_CHAT_ID=

# Feishu/Lark
# JIAOS_FEISHU_WEBHOOK_URL=

# WeCom
# JIAOS_WECOM_WEBHOOK_URL=

# =============================================================================
# Daemon Mode (optional)
# =============================================================================

# Market radar cron
# JIAOS_DAEMON_RADAR_CRON=0 6 * * 1

# Write cycle cron
# JIAOS_DAEMON_WRITE_CRON=0 */4 * * *
